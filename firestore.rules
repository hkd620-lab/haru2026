rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/records/{recordId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if (request.auth != null && request.auth.uid == userId)
        || userId == "naver_lGu8c7z0B13JzA5ZCn_sTu4fD7VcN3dydtnt0t5PZ-8";
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{uid}/settings/{settingId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /users/{uid}/readProgress/{bookId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /books/{bookId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.uid == "naver_lGu8c7z0B13JzA5ZCn_sTu4fD7VcN3dydtnt0t5PZ-8";
      match /chapters/{chapterId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null &&
          request.auth.uid == "naver_lGu8c7z0B13JzA5ZCn_sTu4fD7VcN3dydtnt0t5PZ-8";
      }
      match /characters/{charId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null &&
          request.auth.uid == "naver_lGu8c7z0B13JzA5ZCn_sTu4fD7VcN3dydtnt0t5PZ-8";
      }
      match /sources/{sourceId} {
        allow read: if request.auth != null &&
          request.auth.uid == "naver_lGu8c7z0B13JzA5ZCn_sTu4fD7VcN3dydtnt0t5PZ-8";
        allow write: if request.auth != null &&
          request.auth.uid == "naver_lGu8c7z0B13JzA5ZCn_sTu4fD7VcN3dydtnt0t5PZ-8";
      }
    }
    match /news/{docId} {
      allow read: if true;
      allow write: if request.auth != null &&
        request.auth.uid == "naver_lGu8c7z0B13JzA5ZCn_sTu4fD7VcN3dydtnt0t5PZ-8";
    }
    match /lawConsultCache/{cacheId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /users/{uid}/novelSettings/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /prophecyUsage/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /grammarCache/{cacheId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /quizCache/{cacheId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /grammarErrorReports/{reportId} {
      allow read: if request.auth != null &&
        request.auth.uid == "naver_lGu8c7z0B13JzA5ZCn_sTu4fD7VcN3dydtnt0t5PZ-8";
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // 사용자 설정 (FCM 토큰 포함)
    match /users/{userId}/settings/{docId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // 뉴스 컬렉션
    match /news/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.uid == "naver_lGu8c7z0B13JzA5ZCn_sTu4fD7VcN3dydtnt0t5PZ-8";
    }

    // 이메일-UID 매핑
    match /email_to_uid/{docId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == "naver_lGu8c7z0B13JzA5ZCn_sTu4fD7VcN3dydtnt0t5PZ-8";
    }

    // 법률 상담 캐시
    match /lawConsultCache/{cacheId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 구독 정보
    match /subscription/{docId} {
      allow read: if request.auth != null &&
        request.auth.uid == docId;
      allow write: if false;
    }

    // 단어장
    match /vocabulary/{docId} {
      allow read, write, delete: if request.auth != null;
    }

    // 텃밭 작물
    match /gardenCrops/{docId} {
      allow read, write, delete: if request.auth != null;
    }

    // 소설 설정
    match /novelSettings/{docId} {
      allow read, write: if request.auth != null;
    }

    // 성경 학습이력
    match /users/{userId}/bibleProgress/{docId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // 성경 단어장
    match /users/{userId}/bibleWordbook/{docId} {
      allow read, write, delete: if request.auth != null
        && request.auth.uid == userId;
    }

    // SNS 기록 가져오기 (Facebook ZIP 분석 결과)
    match /users/{uid}/snsRecords/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
