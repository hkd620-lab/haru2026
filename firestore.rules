rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 사용자별 기록 데이터 (서브컬렉션 구조)
    match /users/{userId}/records/{recordId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // 책 스튜디오 — books 컬렉션
    match /books/{bookId} {
      // 읽기: 로그인한 구독자
      allow read: if request.auth != null;

      // 쓰기: 개발자만
      allow write: if request.auth != null &&
        request.auth.uid == "naver_lGu8c7z0B13JzA5ZCn_sTu4fD7VcN3dydtnt0t5PZ-8";

      // 챕터
      match /chapters/{chapterId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null &&
          request.auth.uid == "naver_lGu8c7z0B13JzA5ZCn_sTu4fD7VcN3dydtnt0t5PZ-8";
      }

      // 인물
      match /characters/{charId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null &&
          request.auth.uid == "naver_lGu8c7z0B13JzA5ZCn_sTu4fD7VcN3dydtnt0t5PZ-8";
      }

      // 소스
      match /sources/{sourceId} {
        allow read: if request.auth != null &&
          request.auth.uid == "naver_lGu8c7z0B13JzA5ZCn_sTu4fD7VcN3dydtnt0t5PZ-8";
        allow write: if request.auth != null &&
          request.auth.uid == "naver_lGu8c7z0B13JzA5ZCn_sTu4fD7VcN3dydtnt0t5PZ-8";
      }
    }

    // 독자 읽기 기록
    match /users/{uid}/readProgress/{bookId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /grammarCache/{cacheId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /quizCache/{cacheId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /grammarErrorReports/{reportId} {
      allow read: if request.auth != null &&
        request.auth.uid == "naver_lGu8c7z0B13JzA5ZCn_sTu4fD7VcN3dydtnt0t5PZ-8";
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // 사용자 설정 (FCM 토큰 포함)
    match /users/{userId}/settings/{docId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // 뉴스 컬렉션
    match /news/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.uid == "naver_lGu8c7z0B13JzA5ZCn_sTu4fD7VcN3dydtnt0t5PZ-8";
    }

    // 이메일-UID 매핑
    match /email_to_uid/{docId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == "naver_lGu8c7z0B13JzA5ZCn_sTu4fD7VcN3dydtnt0t5PZ-8";
    }

    // 법률 상담 캐시
    match /lawConsultCache/{cacheId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 구독 정보
    match /subscription/{docId} {
      allow read: if request.auth != null &&
        request.auth.uid == docId;
      allow write: if false;
    }

    // 단어장
    match /vocabulary/{docId} {
      allow read, write, delete: if request.auth != null;
    }

    // 텃밭 작물
    match /gardenCrops/{docId} {
      allow read, write, delete: if request.auth != null;
    }

    // 소설 설정
    match /novelSettings/{docId} {
      allow read, write: if request.auth != null;
    }

    // 성경 학습이력
    match /users/{userId}/bibleProgress/{docId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // 성경 단어장
    match /users/{userId}/bibleWordbook/{docId} {
      allow read, write, delete: if request.auth != null
        && request.auth.uid == userId;
    }
  }
}