rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // 사용자별 이미지 업로드 허용 (records 내부)
    match /users/{userId}/records/{recordId}/{format}/images/{imageId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ✅ FormatModal 업로드 경로(users/{uid}/format_photos/...) 허용
    match /users/{userId}/format_photos/{fileName} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write, delete: if request.auth != null && request.auth.uid == userId;
    }

    // ✅ SNS 기록 가져오기 — Facebook ZIP 업로드 경로 (분석 후 함수가 삭제)
    match /users/{userId}/snsUploads/{fileName} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write, delete: if request.auth != null && request.auth.uid == userId;
    }

    // ✅ SNS 기록 가져오기 — 분석 결과 썸네일 (Functions가 생성·makePublic 처리)
    match /users/{userId}/snsThumbnails/{docId}/{fileName} {
      allow read: if true;
      allow write, delete: if false;
    }
  }
}
