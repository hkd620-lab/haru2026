{
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./.env.local)",
      "Read(./.env.production)",
      "Read(./.env.development)",
      "Read(./functions/.env)",
      "Read(./functions/.env.*)",
      "Read(./frontend/.env)",
      "Read(./frontend/.env.*)",
      "Read(./**/*secret*)",
      "Read(./**/*credential*)",
      "Read(./**/*firebase-adminsdk*)"
    ]
  }
}
